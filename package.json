{
  "name": "caloriex",
  "version": "0.1.0",
  "private": true,
  "description": "calorieX — AI-powered calorie tracking app (Turborepo + Bun monorepo)",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d postgres",
    "db:logs": "docker compose logs -f postgres",
    "db:generate": "cd packages/db && bun --env-file=../../.env run generate",
    "db:push": "cd packages/db && bun --env-file=../../.env run push",
    "db:migrate": "cd packages/db && bun --env-file=../../.env run migrate",
    "db:studio": "cd packages/db && bun --env-file=../../.env run studio",
    "db:seed": "cd packages/db && bun --env-file=../../.env run seed",
    "db:seed:exercises": "cd packages/db && bun --env-file=../../.env run seed:exercises"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.6.3",
    "@types/bun": "^1.1.14",
    "prettier": "^3.3.3"
  },
  "packageManager": "bun@1.3.0",
  "engines": {
    "bun": ">=1.1.0"
  }
}
