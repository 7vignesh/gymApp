{
  "name": "@caloriex/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "src/server.ts",
  "scripts": {
    "dev": "bun run --hot --env-file=../../.env src/server.ts",
    "build": "bun build src/server.ts --target bun --outdir dist",
    "start": "bun --env-file=../../.env run dist/server.js",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "clean": "rm -rf node_modules dist .turbo"
  },
  "dependencies": {
    "@caloriex/db": "workspace:*",
    "@hono/zod-validator": "^0.4.1",
    "hono": "^4.6.14",
    "jose": "^5.9.6",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@caloriex/config": "workspace:*",
    "@types/bun": "^1.1.14",
    "typescript": "^5.6.3"
  }
}
